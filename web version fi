"""
FI.se Fund Holdings - Auto-download latest ZIP + convert to Excel
Scrapes https://www.fi.se/en/our-registers/quarterly-fund-holdings/
Downloads the latest quarterly ZIP, extracts all XML files, and writes
all holdings into one combined Excel sheet.

Run in PyCharm: just click the green Run button.
If auto-download fails, set MANUAL_ZIP_PATH to a local ZIP file instead.
"""

import re
import sys
import zipfile
import logging
import time
from pathlib import Path
from xml.etree import ElementTree as ET

import requests
from bs4 import BeautifulSoup
import openpyxl
from openpyxl.styles import Font, PatternFill, Alignment
from openpyxl.utils import get_column_letter

logging.basicConfig(level=logging.INFO, format="%(asctime)s  %(levelname)s  %(message)s")
log = logging.getLogger(__name__)

# ===========================================================================
# OPTION A: Leave as "" to auto-download the latest ZIP from FI.se
# OPTION B: Set to a local ZIP path if you downloaded it manually
#   e.g.  MANUAL_ZIP_PATH = r"C:\Downloads\Fondinnehav 2026Q1 2026-06-10 14.48.zip"
# ===========================================================================
MANUAL_ZIP_PATH = ""
# ===========================================================================

PAGE_URL     = "https://www.fi.se/en/our-registers/quarterly-fund-holdings/"
BASE_URL     = "https://www.fi.se"
DOWNLOAD_DIR = Path("fi_downloads")
OUTPUT_FILE  = Path("fi_fund_holdings_combined.xlsx")

NS = "http://schemas.fi.se/publika/vardepappersfonder/20200331"

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/124.0.0.0 Safari/537.36"
    ),
    "Accept-Language": "en-US,en;q=0.9",
}


def get_with_retry(url: str, stream: bool = False) -> requests.Response:
    for attempt, wait in enumerate([2, 4, 8, 16], start=1):
        try:
            resp = requests.get(url, headers=HEADERS, stream=stream, timeout=60)
            resp.raise_for_status()
            return resp
        except requests.RequestException as exc:
            if attempt == 4:
                raise
            log.warning("Request failed (%s), retrying in %ss...", exc, wait)
            time.sleep(wait)


def parse_quarter(filename: str):
    m = re.search(r"(\d{4})Q(\d)", filename, re.I)
    if m:
        return int(m.group(1)), int(m.group(2))
    return (0, 0)


def find_latest_zip_url() -> tuple[str, str]:
    log.info("Fetching FI.se fund holdings page...")
    resp = get_with_retry(PAGE_URL)
    soup = BeautifulSoup(resp.text, "html.parser")

    zips = []
    for a in soup.find_all("a", href=True):
        href = a["href"]
        if href.lower().endswith(".zip"):
            label = a.get_text(strip=True) or Path(href).name
            full_url = href if href.startswith("http") else BASE_URL + href
            zips.append((label, full_url))

    if not zips:
        raise RuntimeError(
            "No ZIP links found on the FI.se page. "
            "Set MANUAL_ZIP_PATH to your downloaded ZIP file instead."
        )

    zips.sort(key=lambda x: parse_quarter(x[0]), reverse=True)
    latest_label, latest_url = zips[0]
    log.info("Latest ZIP found: %s", latest_label)
    return latest_url, latest_label


def download_zip(url: str, label: str) -> Path:
    DOWNLOAD_DIR.mkdir(exist_ok=True)
    safe_name = re.sub(r'[<>:"/\\|?*]', "_", label)
    if not safe_name.lower().endswith(".zip"):
        safe_name += ".zip"
    dest = DOWNLOAD_DIR / safe_name

    if dest.exists():
        log.info("ZIP already downloaded: %s", dest)
        return dest

    log.info("Downloading %s ...", label)
    resp = get_with_retry(url, stream=True)
    with open(dest, "wb") as fh:
        for chunk in resp.iter_content(chunk_size=1 << 16):
            fh.write(chunk)
    log.info("Saved to: %s", dest)
    return dest


def extract_xml_files(zip_path: Path, dest_dir: Path) -> list[Path]:
    log.info("Extracting XML files from ZIP...")
    xml_paths = []
    with zipfile.ZipFile(zip_path) as zf:
        members = [m for m in zf.namelist() if m.lower().endswith(".xml")]
        log.info("Found %d XML file(s).", len(members))
        for member in members:
            extracted = zf.extract(member, dest_dir)
            xml_paths.append(Path(extracted))
    return xml_paths


def t(tag):
    return f"{{{NS}}}{tag}"


def get_text(element, tag, default=""):
    if element is None:
        return default
    child = element.find(t(tag))
    if child is not None and child.text:
        return child.text.strip()
    return default


def parse_xml(xml_path: Path, extract_dir: Path) -> list[dict]:
    try:
        tree = ET.parse(xml_path)
    except ET.ParseError as exc:
        log.warning("Could not parse %s: %s", xml_path.name, exc)
        return []

    root = tree.getroot()

    try:
        folder_name = xml_path.relative_to(extract_dir).parts[0] if len(xml_path.relative_to(extract_dir).parts) > 1 else ""
    except ValueError:
        folder_name = ""

    rapport      = root.find(t("Rapportinformation"))
    quarter      = get_text(rapport, "Kvartalsslut")
    bolag        = root.find(t("Bolagsinformation"))
    company_name = get_text(bolag, "Fondbolag_namn")
    company_lei  = get_text(bolag, "Fondbolag_LEI-kod")

    rows = []
    for fond_info in root.findall(t("Fondinformation")):
        fund_isin = get_text(fond_info, "Fond_ISIN-kod")
        fund_name = get_text(fond_info, "Fond_namn")
        fund_nav  = get_text(fond_info, "Fondförmögenhet")

        if not fund_name:
            continue

        instruments = fond_info.find(t("FinansiellaInstrument"))
        if instruments is None:
            continue

        for instrument in instruments.findall(t("FinansielltInstrument")):
            bransch = instrument.find(t("Bransch"))
            rows.append({
                "Quarter":            quarter,
                "Folder":             folder_name,
                "Source File":        xml_path.name,
                "Fund Company":       company_name,
                "Fund Company LEI":   company_lei,
                "Fund ISIN":          fund_isin,
                "Fund Name":          fund_name,
                "Fund NAV (SEK)":     fund_nav,
                "Instrument Type":    get_text(instrument, "Tillgångsslag_enligt_LVF_5_kap"),
                "Holding Name":       get_text(instrument, "Instrumentnamn"),
                "Holding ISIN":       get_text(instrument, "ISIN-kod_instrument"),
                "Country":            get_text(instrument, "Landkod_Emittent"),
                "Currency":           get_text(instrument, "Valuta"),
                "Quantity":           get_text(instrument, "Antal"),
                "Nominal Amount":     get_text(instrument, "Nominellt_belopp"),
                "Market Value (SEK)": get_text(instrument, "Marknadsvärde_instrument"),
                "% of NAV":           get_text(instrument, "Andel_av_fondförmögenhet_instrument"),
                "Sector Code":        get_text(bransch, "Branschkod_instrument") if bransch is not None else "",
                "Sector Name":        get_text(bransch, "Bransch_namn_instrument") if bransch is not None else "",
            })

    return rows


COLUMNS = [
    "Quarter", "Folder", "Source File",
    "Fund Company", "Fund Company LEI",
    "Fund ISIN", "Fund Name", "Fund NAV (SEK)",
    "Instrument Type", "Holding Name", "Holding ISIN",
    "Country", "Currency", "Quantity", "Nominal Amount",
    "Market Value (SEK)", "% of NAV", "Sector Code", "Sector Name",
]

HEADER_FILL  = PatternFill("solid", fgColor="1F4E79")
HEADER_FONT  = Font(bold=True, color="FFFFFF", size=10)
ALT_ROW_FILL = PatternFill("solid", fgColor="D6E4F0")


def write_excel(all_rows: list[dict], output_path: Path) -> None:
    log.info("Writing %d rows to Excel...", len(all_rows))
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = "Fund Holdings"

    ws.append(COLUMNS)
    for col_idx in range(1, len(COLUMNS) + 1):
        cell = ws.cell(row=1, column=col_idx)
        cell.fill = HEADER_FILL
        cell.font = HEADER_FONT
        cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
    ws.row_dimensions[1].height = 30
    ws.freeze_panes = "A2"

    for row_num, row_data in enumerate(all_rows, start=2):
        ws.append([row_data.get(col, "") for col in COLUMNS])
        if row_num % 2 == 0:
            for col_idx in range(1, len(COLUMNS) + 1):
                ws.cell(row=row_num, column=col_idx).fill = ALT_ROW_FILL

    for col_idx, col_name in enumerate(COLUMNS, start=1):
        max_len = max(
            len(col_name),
            *(len(str(row_data.get(col_name, "") or "")) for row_data in all_rows)
        ) if all_rows else len(col_name)
        ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len + 2, 60)

    ws.auto_filter.ref = ws.dimensions
    wb.save(output_path)
    log.info("Done! Saved to: %s", output_path.resolve())


def main():
    if MANUAL_ZIP_PATH:
        zip_path = Path(MANUAL_ZIP_PATH)
        if not zip_path.exists():
            log.error("File not found: %s", zip_path)
            sys.exit(1)
        extract_dir = zip_path.parent / (zip_path.stem + "_extracted")
    else:
        try:
            url, label = find_latest_zip_url()
            zip_path = download_zip(url, label)
        except Exception as exc:
            log.error("Auto-download failed: %s", exc)
            log.error("Set MANUAL_ZIP_PATH to your downloaded ZIP file and try again.")
            sys.exit(1)
        extract_dir = DOWNLOAD_DIR / (zip_path.stem + "_extracted")

    extract_dir.mkdir(exist_ok=True)

    xml_paths = extract_xml_files(zip_path, extract_dir)
    if not xml_paths:
        log.error("No XML files found inside the ZIP.")
        sys.exit(1)

    all_rows = []
    for xml_path in sorted(xml_paths):
        rows = parse_xml(xml_path, extract_dir)
        all_rows.extend(rows)
        log.info("  %s -> %d holding rows", xml_path.name, len(rows))

    if not all_rows:
        log.warning("No data rows parsed. Check the XML files in: %s", extract_dir)
        sys.exit(1)

    write_excel(all_rows, OUTPUT_FILE)


if __name__ == "__main__":
    main()
